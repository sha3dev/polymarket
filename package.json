{
  "name": "@sha3/polymarket",
  "version": "0.6.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "fix": "npm run lint:fix && npm run format:write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "publish": "node scripts/release-publish.mjs"
  },
  "devDependencies": {
    "@sha3/code-standards": "^0.1.0",
    "@types/node": "^22.13.10",
    "@types/ws": "^8.18.1",
    "eslint": "^9.20.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sha3dev/polymarket"
  },
  "homepage": "https://github.com/sha3dev/polymarket#readme",
  "bugs": {
    "url": "https://github.com/sha3dev/polymarket/issues"
  },
  "codeStandards": {
    "template": "node-lib",
    "profilePath": null,
    "withAiAdapters": true,
    "lastRefreshWith": "0.1.20"
  },
  "dependencies": {
    "@ethersproject/wallet": "^5.8.0",
    "@polymarket/clob-client": "^5.3.0",
    "@polymarket/order-utils": "^3.0.1",
    "@sha3/logger": "^2.0.0",
    "ws": "^8.18.0"
  }
}

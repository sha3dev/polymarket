{
  "name": "@sha3/polymarket",
  "version": "1.6.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run standards:check && npm run lint && npm run format:check && npm run typecheck && npm run test",
    "fix": "npm run lint:fix && npm run format:write",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format:check": "biome format .",
    "format:write": "biome format . --write",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:stream:realtime": "tsx test/stream-realtime-check.ts",
    "publish": "node scripts/release-publish.mjs",
    "standards:check": "code-standards verify"
  },
  "devDependencies": {
    "@sha3/code-standards": "^0.29.0",
    "@types/node": "^25.4.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "@biomejs/biome": "^2.4.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sha3dev/polymarket"
  },
  "homepage": "https://github.com/sha3dev/polymarket#readme",
  "bugs": {
    "url": "https://github.com/sha3dev/polymarket/issues"
  },
  "codeStandards": {
    "template": "node-lib",
    "profilePath": null,
    "withAiAdapters": true,
    "lastRefactorWith": "0.29.0",
    "contractVersion": "v1"
  },
  "dependencies": {
    "@ethersproject/wallet": "^5.8.0",
    "@polymarket/clob-client": "^5.8.0",
    "@polymarket/order-utils": "^3.0.1",
    "@sha3/logger": "^2.0.0",
    "ws": "^8.19.0"
  }
}
